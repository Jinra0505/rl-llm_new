   reward += 0.2 * (next_state[4] - state[4])\n    elif action in [0, 1, 2] and action == 1:  # road_B\n        reward += 0.15 * (next_state[1] - state[1])\n    \n    # MES to zone B\n    elif action == 10:  # mes_to_B\n        if material > 0.2 and soc > 0.2:\n            reward += 0.25\n    \n    # Strong penalties for wasteful actions\n    if action == 14:  # wait_hold\n        if material > 0.3 and soc > 0.3:\n            reward -= 0.5  # Severe penalty for waiting with resources\n    \n    # Penalize feeder reconfigure without backbone progress\n    if action == 12 and backbone_comm < 0.5:\n        reward -= 0.4\n    \n    # Penalize coordinated without zone B progress\n    if action == 13 and zone_b_comm < 0.6:\n        reward -= 0.4\n    \n    # Resource conservation bonuses\n    if material > 0.3:\n        reward += 0.1\n    if soc > 0.2:\n        reward += 0.05\n    \n    # Late stage entry bonus\n    if stage < 0.66 and next_state[22] >= 0.66:\n        reward += 1.0\n    \n    # Zone B completion milestone\n    if next_state[7] > 0.8 and state[7] <= 0.8:\n        reward += 0.5\n    \n    # Anti-stagnation: penalize repeated MES_to_C\n    if action == 11 and state[23] == 0:  # mes_to_C without constraint\n        if material < 0.4:\n            reward -= 0.3\n    \n    return float(reward)",
