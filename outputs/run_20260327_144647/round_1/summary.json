    \n    # Penalize wasteful actions\n    if action in [12, 13]:  # feeder_reconfigure, coordinated_balanced\n        if backbone_comm < 30:  # Low communication backbone\n            reward -= 0.6\n        elif material < 0.4:\n            reward -= 0.4\n    \n    # Progress reward for weakest zone B\n    zone_b_progress = (next_state[7] + next_state[4] + next_state[1]) - (state[7] + state[4] + state[1])\n    if zone_b_progress > 0:\n        reward += 0.1 * zone_b_progress\n    \n    return reward",
